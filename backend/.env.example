# Backend Environment Variables

# Server Configuration
PORT=3001
NODE_ENV=development

# HTTPS Configuration (for production)
HTTPS_ENABLED=false
HTTPS_KEY_PATH=
HTTPS_CERT_PATH=
HTTPS_PORT=3443

# Database
DATABASE_URL="postgresql://tetris_user:tetris_password@localhost:5432/tetris_db"

# JWT Secrets
JWT_SECRET=tetris_secret_key_change_in_production
REFRESH_JWT_SECRET=tetris_refresh_secret_key_change_in_production

# CORS Configuration
CORS_ORIGIN=http://localhost:4200
CORS_CREDENTIALS=true

# Cookie Configuration
COOKIE_MAX_AGE_DAYS=7
COOKIE_SECURE=false
COOKIE_SAME_SITE=strict
COOKIE_HTTP_ONLY=true
COOKIE_PATH=/

# Security
BCRYPT_ROUNDS=10

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
COOKIE_SAME_SITE=strict
COOKIE_HTTP_ONLY=true
COOKIE_PATH=/

# Security
BCRYPT_ROUNDS=12