# Production Environment Variables

# Server Configuration
PORT=3001
NODE_ENV=production

# HTTPS Configuration
HTTPS_ENABLED=true
HTTPS_KEY_PATH=/path/to/your/private.key
HTTPS_CERT_PATH=/path/to/your/certificate.crt
HTTPS_PORT=3443

# Database (використовуйте production database URL)
DATABASE_URL="postgresql://prod_user:secure_password@db-host:5432/tetris_prod"

# JWT Secrets (ОБОВ'ЯЗКОВО змініть на унікальні ключі)
JWT_SECRET=your_very_secure_jwt_secret_key_here
REFRESH_JWT_SECRET=your_very_secure_refresh_jwt_secret_key_here

# CORS Configuration
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com
CORS_CREDENTIALS=true

# Cookie Configuration
COOKIE_MAX_AGE_DAYS=7
COOKIE_SECURE=true
COOKIE_SAME_SITE=strict
COOKIE_HTTP_ONLY=true
COOKIE_PATH=/
COOKIE_DOMAIN=yourdomain.com

# Security
BCRYPT_ROUNDS=12

# Rate limiting (stricter for production)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=50
RATE_LIMIT_MAX_REQUESTS=100